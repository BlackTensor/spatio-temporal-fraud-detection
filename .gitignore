# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ---- Virtual environments ----
venv/
.venv/
env/
ENV/
.conda/

# ---- Jupyter ----
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# ---- Data (free datasets re-downloadable; keep raw out of git) ----
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
*.csv
*.parquet
*.feather
# Allow small tracked CSVs in results (e.g. comparison tables)
!results/*.csv
!config/*.csv

# ---- PyTorch / model artifacts (large -> HuggingFace Hub, not git) ----
*.pt
*.pth
*.ckpt
*.onnx
*.pkl
*.joblib
!results/.gitkeep

# ---- Results: keep small reports/plots, ignore heavy arrays ----
*.npy
*.npz
results/*.h5

# ---- ML experiment tracking / caches ----
.cache/
mlruns/
wandb/
lightning_logs/

# ---- Kaggle credentials (NEVER commit) ----
kaggle.json
.kaggle/

# ---- Environment / secrets ----
.env
*.local

# ---- OS / IDE ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ---- Misc ----
*.log
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
install_log.txt
